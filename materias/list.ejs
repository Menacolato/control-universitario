<%- include("../partials/head") %>
<%- include("../partials/navbar") %>

<div class="row">
  <h1>Materias</h1>
  <a class="btn" href="/materias/new">+ Nueva</a>
</div>

<table>
  <thead>
    <tr><th>Código</th><th>Materia</th><th>UV</th><th>Acciones</th></tr>
  </thead>
  <tbody>
    <% materias.forEach(m => { %>
      <tr>
        <td><%= m.codigo %></td>
        <td><%= m.nombre %></td>
        <td><%= m.uv %></td>
        <td class="actions">
          <a href="/materias/<%= m.id %>/edit">Editar</a>
          <form method="POST" action="/materias/<%= m.id %>?_method=DELETE" class="inline">
            <button class="danger" type="submit" onclick="return confirm('¿Eliminar materia?')">Eliminar</button>
          </form>
        </td>
      </tr>
    <% }) %>
  </tbody>
</table>

<%- include("../partials/footer") %>